<?xml version="1.0" encoding="utf-8"?>
<!-- Glowing shield background for inactive/compromised state -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/shield_inactive_glow" />
            <size android:width="80dp" android:height="80dp" />
        </shape>
    </item>
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#1AEF5350" />
        </shape>
    </item>
</layer-list>
