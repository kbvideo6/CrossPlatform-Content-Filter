<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OmegaLite" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/emerald_green</item>
        <item name="colorPrimaryVariant">@color/emerald_green_dim</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorSecondaryVariant">@color/brand_deep_blue</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <!-- Dark backgrounds -->
        <item name="android:colorBackground">@color/background_primary</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar & navigation -->
        <item name="android:statusBarColor">@color/background_primary</item>
        <item name="android:navigationBarColor">@color/background_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/OmegaCard</item>
    </style>

    <!-- Card style override -->
    <style name="OmegaCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Section header text style -->
    <style name="CardHeader">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Card title text style -->
    <style name="CardTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Monospace data style -->
    <style name="MonoData">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/text_mono</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <!-- Stat number style -->
    <style name="StatNumber">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <!-- Stat label style -->
    <style name="StatLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Dialog theme for Add Domain -->
    <style name="OmegaDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/background_card</item>
        <item name="colorSurface">@color/background_card</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
</resources>
